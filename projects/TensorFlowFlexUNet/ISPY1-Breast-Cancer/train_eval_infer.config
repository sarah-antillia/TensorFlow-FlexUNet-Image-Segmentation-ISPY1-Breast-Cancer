; train_eval_infer.config
; 2026/06/04 (C) antillia.com
; IPSY1-Breast-Cancer egmentation
[model]
model         = "TensorFlowFlexUNet"
generator     =  False

image_width    = 512
image_height   = 512
image_channels = 3
input_normalize = True
normalization  = False
num_classes    = 2
base_filters   = 16
base_kernels   = (11,11)
num_layers     = 8
dropout_rate   = 0.05
dilation       = (1,1)

; Model compilation parameters
optimizer       = "Adam"

learning_rate  = 0.00007
clipvalue      = 0.5

; Specify "categorical_crossentropy" function to loss
; for categoraized(one-hot-encoded) mask 
loss           = "categorical_crossentropy"
metrics        = ["dice_coef_multiclass"]

show_summary   = False

[dataset]
class_name    = "ImageCategorizedMaskDataset"

[train]
;epochs       = 50
epochs        = 100
batch_size    = 2

;steps_per_epoch  = 200
;validation_steps = 80

; EarlyStopping parameter
patience      = 10

metrics       = ["dice_coef_multiclass", "val_dice_coef_multiclass"]

model_dir     = "./models/"
eval_dir      = "./eval/"
images_dir    = "../../../dataset/IPSY1-Breast-Cancer/train/images/"
masks_dir     = "../../../dataset/IPSY1-Breast-Cancer/train/masks/"

create_backup  = False

; learning_rate_reducer callback parameter
learning_rate_reducer = True
reducer_factor     = 0.4
reducer_patience   = 4

; Model saving option
save_weights_only  = True

[valid]
images_dir = "../../../dataset/IPSY1-Breast-Cancer/valid/images/"
masks_dir  = "../../../dataset/IPSY1-Breast-Cancer/valid/masks/"

[test] 
images_dir = "../../../dataset/IPSY1-Breast-Cancer/test/images/"
masks_dir  = "../../../dataset/IPSY1-Breast-Cancer/test/masks/"

[infer] 
images_dir    = "./mini_test/images/"
output_dir    = "./mini_test_output/"

[infer3d] 
;Specify an images_dir of NIfTI, MHA or NPY volume files
images_dir    = "./mini_test_3d/images/"

output_dir    = "./mini_test_3d_output/"

slice_normalize = True
slice_shape_order = "hwd"
slice_resize   = (512,512)
slice_rotation = "cv2.ROTATE_90_COUNTERCLOCKWISE" 

mask_overlay  = True

video_fps        = 10
;video_fileformat  = ".mp4"
video_fileformat  = ".gif"

[image]
color_order = "RGB"

[mask]
mask_datatyoe    = "categorized"
mask_file_format = ".png"
;IPSY1-Breast-Cancer rgb color map dict for 1+1 classes.
;                     Cancer:dark red
rgb_map = {(0,0,0):0, (180,40,40):1 }
